    "version": "0.2.0",
    "configurations": [
        {
            "name": "flare_dating_app (Chrome No Debug)",
            "cwd": "flare_dating_app",
            "request": "launch",
            "type": "dart",
            "args": [
                "-d",
                "chrome"
            ],
            "noDebug": true
        },
        {
            "name": "flare_dating_app",
            "cwd": "flare_dating_app",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "flare_dating_app (profile mode)",
            "cwd": "flare_dating_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "flare_dating_app (release mode)",
            "cwd": "flare_dating_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}